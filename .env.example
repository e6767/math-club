PORT=3000
SESSION_SECRET=change-this-to-a-long-random-string
CLUB_NAME=Lincoln High Math Club
# Optional: restrict registration to a school email domain, leave blank to allow any email
SCHOOL_EMAIL_DOMAIN=
# The first account ever registered is automatically made an admin.

# --- Email (optional) ---
# Lets officers/admins email all members from the dashboard. Leave blank to
# disable sending (the feature stays visible but shows a "not configured" notice).
# Works with any SMTP provider (AWS SES, SendGrid, Mailgun, Gmail app password, ...).
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
# The "From" address members see (must be a verified sender with your provider).
MAIL_FROM=

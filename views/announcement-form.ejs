<%- include('partials/header', { title: 'New announcement' }) %>

<h1>New announcement</h1>
<% if (error) { %><div class="error-box"><%= error %></div><% } %>
<form class="stack" method="POST" action="/announcements/new">
  <div>
    <label for="title">Title</label>
    <input type="text" id="title" name="title" value="<%= announcement.title || '' %>" required />
  </div>
  <div>
    <label for="body">Message</label>
    <textarea id="body" name="body" required><%= announcement.body || '' %></textarea>
  </div>
  <button class="btn btn-accent" type="submit">Post announcement</button>
</form>

<%- include('partials/footer') %>
